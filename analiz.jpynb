      "Activity_Group                              \n",
      "Aşırı Spor       75.055556          6.388889\n",
      "Normal Spor      70.798319          7.016807\n"
     ]
    }
   ],
   "source": [
    "df_health['Activity_Group'] = df_health['Physical Activity Level'].apply(lambda x: 'Aşırı Spor' if x > 80 else 'Normal Spor')\n",
    "\n",
    "# Grupların ortalama uyanma sayılarına ve nabızlarına bakalım\n",
    "summary = df_health.groupby('Activity_Group')[['Heart Rate', 'Quality of Sleep']].mean()\n",
    "print(summary)"
   ]
  },
