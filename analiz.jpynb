  {
   "cell_type": "code",
   "execution_count": 251,
   "id": "d574c252",
   "metadata": {},
   "outputs": [],
   "source": [
    "# HİPOTEZ: Alkol ve sigara uykuyu bölen beklenen sebeplerdir; ancak beklenmedik şekilde, çok fazla spor yapmak da nabzı yüksek tutarak\n",
    "# derin uykuya dalmayı imkansız hale getirir.\"\n",
    "\n",
    "#1.BEKLENEN BULGU: Alkol ve sigara uykuyu doğrudan parçalıyor. \n",
    "#Verilerimiz, bu maddeleri kullananların gece uykularının 2 kat daha fazla \n",
    "#kesildiğini (Awakenings) kanıtlıyor.\n",
    "\n",
    "#2.BEKLENMEYEN BULGU: Hiçbir kötü alışkanlığı olmayan 'sağlıklı' \n",
    "#insanlarda ise uykuyu bölen gizli sebep: Aşırı Spor. \n",
    "#Analizimiz şunu gösterdi: Çok ağır spor sonrası düşmeyen nabız (75 bpm), \n",
    "#vücudun hafif uykuda takılı kalmasına ve aniden uyanmalara sebep oluyor."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 252,
   "id": "96ce8468",
   "metadata": {},
   "outputs": [],
   "source": [
    "#\"Verilerde görülen Daily Steps ve Heart Rate arasındaki -0.96'lık güçlü negatif korelasyon, normal şartlarda fiziksel aktivitenin kalp sağlığını\n",
    "# desteklediğini göstermektedir. Ancak hipotezimiz çerçevesinde 'Aşırı Spor' grubu incelendiğinde; aktivite seviyesinin belirli bir eşiği aşmasının \n",
    "# nabızda anormal bir yükselmeye (75 bpm) yol açtığı saptanmıştır. Bu yüksek nabız, Light Sleep ve Deep Sleep arasındaki -0.98'lik ters ilişkiyi tetikleyerek;\n",
    "# vücudun hafif uykuda kalmasına ve bilişsel onarım için kritik olan derin uyku evresine geçiş yapamamasına neden olmaktadır.\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 253,
   "id": "c51d42d6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Efficiency Sütunları: ['ID', 'Age', 'Gender', 'Bedtime', 'Wakeup time', 'Sleep duration', 'Sleep efficiency', 'REM sleep percentage', 'Deep sleep percentage', 'Light sleep percentage', 'Awakenings', 'Caffeine consumption', 'Alcohol consumption', 'Smoking status', 'Exercise frequency']\n",
      "Health Sütunları: ['Person ID', 'Gender', 'Age', 'Occupation', 'Sleep Duration', 'Quality of Sleep', 'Physical Activity Level', 'Stress Level', 'BMI Category', 'Blood Pressure', 'Heart Rate', 'Daily Steps', 'Sleep Disorder']\n"
     ]
    }
   ],
   "source": [
    "print(\"Efficiency Sütunları:\", df_eff.columns.tolist())\n",
    "print(\"Health Sütunları:\", df_health.columns.tolist())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 254,
   "id": "44b763f1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "--- Alkol ve Sigara Etkisi ---\n",
      "Risk_Grubu\n",
      "Riskli (Alkol/Sigara)    1.714286\n",
      "Temiz Yaşam              1.466667\n",
      "Name: Awakenings, dtype: float64\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "# Alkol ve Sigara tüketenler ile tüketmeyenleri ayıralım\n",
    "df_eff['Risk_Grubu'] = df_eff.apply(lambda x: 'Riskli (Alkol/Sigara)' if (x['Alcohol consumption'] > 0 or x['Smoking status'] == 'Yes') else 'Temiz Yaşam', axis=1)\n",
    "\n",
    "# Uyanma sayıları (Awakenings) ortalamasına bakalım\n",
    "alkol_sigara_analiz = df_eff.groupby('Risk_Grubu')['Awakenings'].mean()\n",
    "print(\"--- Alkol ve Sigara Etkisi ---\")\n",
    "print(alkol_sigara_analiz)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 255,
